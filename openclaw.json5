{
  // ChesedClaw Gateway Config
  // AA-CMA: Thomas + Seneca + Aris + Arc
  // OpenAI Codex OAuth (GPT-5.4 Pro) until Mac Minis arrive

  gateway: {
    mode: "local",
  },

  channels: {
    telegram: {
      enabled: true,
      // Bot token from env: TELEGRAM_BOT_TOKEN
      dmPolicy: "allowlist",
      allowFrom: [1657029840],
      groups: {
        "*": { requireMention: true },
      },
    },
  },

  agents: {
    defaults: {
      model: "openai-codex/gpt-5.4",
    },
    list: [
      {
        id: "thomas",
        default: true,
        identity: { name: "Thomas Aquinas" },
        model: "openai-codex/gpt-5.4",
        workspace: "~/aa-cma/workspace-thomas",
        subagents: {
          allowAgents: ["seneca", "aris", "arc"],
        },
        tools: {
          allow: [
            "read", "write", "edit", "glob", "grep", "exec",
            "message", "cron",
            "sessions_list", "sessions_history",
            "sessions_spawn", "sessions_send", "session_status",
            "browser",
          ],
        },
      },
      {
        id: "seneca",
        identity: { name: "Seneca" },
        model: "openai-codex/gpt-5.4",
        workspace: "~/aa-cma/workspace-seneca",
        subagents: {
          allowAgents: ["*"],
        },
        tools: {
          allow: [
            "read", "write", "edit", "glob", "grep", "exec",
            "browser", "sessions_spawn",
          ],
          deny: ["message", "cron"],
        },
      },
      {
        id: "aris",
        identity: { name: "Aristotle" },
        model: "openai-codex/gpt-5.4",
        workspace: "~/aa-cma/workspace-aris",
        subagents: {
          allowAgents: ["*"],
        },
        tools: {
          allow: [
            "read", "write", "glob", "grep", "exec",
            "browser", "sessions_spawn",
          ],
          deny: ["message", "cron", "edit"],
        },
      },
      {
        id: "arc",
        identity: { name: "Archimedes" },
        model: "openai-codex/gpt-5.4",
        workspace: "~/aa-cma/workspace-arc",
        tools: {
          allow: [
            "read", "write", "edit", "glob", "grep", "exec",
          ],
          deny: ["message", "browser", "cron", "sessions_spawn"],
        },
      },
    ],
  },

  // Bindings MUST be top-level (not nested under agents)
  bindings: [
    { agentId: "thomas", match: { channel: "telegram" } },
  ],

  tools: {
    agentToAgent: {
      enabled: true,
      allow: ["thomas", "seneca", "aris", "arc"],
    },
  },
}
